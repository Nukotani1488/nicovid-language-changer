{
    "manifest_version": 2,
    "name": "NicoNico Language Changer",
    "version": "1.0",
    "description": "Change language from the header.",
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "64": "icons/icon64.png",
        "128": "icons/icon128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.nicovideo.jp/**"
            ],
            "js": [
                "addheaderentry.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "permissions": [
        "storage",
        "cookies",
        "*://*/*"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "@addon-example",
            "strict_min_version": "58.0"
        }
    }
}