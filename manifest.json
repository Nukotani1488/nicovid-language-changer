{
    "manifest_version": 2,
    "name": "NicoNico Language Changer",
    "version": "1.0",
    "description": "Change language from the player menu.",
    "icons": {
        "48": "icons/icon48.png"
    },
    "content_scripts": [
        {
            "matches": [
                "*://www.nicovideo.jp/watch/*"
            ],
            "js": [
                "addmenuentry.js"
            ]
        }
    ]
}