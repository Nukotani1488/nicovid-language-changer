{
    "manifest_version": 2,
    "name": "NicoNico Language Changer",
    "version": "1.0",
    "description": "Change language from the header.",
    "icons": {
        "32": "icons/icon32.png",
        "64": "icons/icon64.png"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.nicovideo.jp/**"
            ],
            "js": [
                "addheaderentry.js"
            ],
            "run_at": "document_idle"
        }
    ]
}